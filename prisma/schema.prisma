// BDU Muslims Academic Bot - Final Corrected Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Department {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  materials Material[]
}

model Material {
  id           Int        @id @default(autoincrement())
  title        String
  fileId       String
  year         Int?       // Exit Exam አመት ስለማይኖረው Optional (?) አደረግነው
  semester     Int?       // Exit Exam ሴሚስተር ስለማይኖረው Optional (?) አደረግነው
  category     Category
  examType     ExamType?  
  courseName   String?    // ለአንዳንድ ፋይሎች የግድ አስፈላጊ ላይሆን ስለሚችል ? አደረግነው
  department   Department @relation(fields: [departmentId], references: [id])
  departmentId Int
}

enum Category {
  Exam
  Handout
  ExitExam   // ይህ ካልተጨመረ Exit Exam ዳታ ስትሞዪ ስህተት ያሳያል
}

enum ExamType {
  Mid
  Final
}