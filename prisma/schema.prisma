// BDU Muslims Academic Bot - Final Corrected Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Department {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  materials Material[]
}

model Material {
  id           Int        @id @default(autoincrement())
  title        String
  fileId       String?    
  fileUrl      String?    // የድራይቭ ሊንክ መቀበያ
  year         Int?
  semester     Int?
  category     Category
  examType     ExamType?  
  courseName   String?
  
  // departmentId እና department ላይ "?" ጨምሬባቸዋለሁ (Optional እንዲሆኑ)
  // ምክንያቱም Common Exams ዲፓርትመንት ላያስፈልጋቸው ይችላል
  department   Department? @relation(fields: [departmentId], references: [id])
  departmentId Int?
}

enum Category {
  Exam
  Handout
  ExitExam
  CommonExam   // ይህ ነው "Mid & Final Exam" ማዕከል ላይ እንዲታይ የሚያደርገው!
}

enum ExamType {
  Mid
  Final
}